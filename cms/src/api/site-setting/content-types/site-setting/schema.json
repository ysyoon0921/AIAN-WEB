{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Settings",
    "description": "Global site configuration"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "siteName": {
      "type": "string",
      "default": "AIAN"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "footerTagline": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "navCtaLabel": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "logoMark": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "logoWordmark": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
