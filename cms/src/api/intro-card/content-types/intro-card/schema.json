{
  "kind": "collectionType",
  "collectionName": "intro_cards",
  "info": {
    "singularName": "intro-card",
    "pluralName": "intro-cards",
    "displayName": "Intro Card",
    "description": "About intro page cards (like Case Study entries)"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "slug": { "type": "string", "required": true, "unique": true },
    "title": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "body": { "type": "text", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "sortOrder": { "type": "integer", "default": 0 }
  }
}
